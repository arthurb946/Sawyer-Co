<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sawyer & Co — Hospitality Photography</title>
  <meta name="description" content="Restaurant and hospitality photography that makes people hungry before they arrive. Based in the UK." />

  <!-- Open Graph -->
  <meta property="og:title" content="Sawyer & Co — Hospitality Photography" />
  <meta property="og:description" content="Photography for restaurants worth remembering." />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ─── TOKENS ─────────────────────────────────────────── */
    :root {
      --bg:           #f9f7f4;
      --bg-dark:      #111010;
      --surface:      #f1eeea;
      --text:         #1a1917;
      --text-muted:   #7a756e;
      --text-light:   #c8c2ba;
      --accent:       #b8946a;
      --accent-warm:  #d4a97a;
      --white:        #ffffff;

      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body:    'DM Sans', system-ui, sans-serif;

      --ease-out:     cubic-bezier(0.16, 1, 0.3, 1);
      --ease-in-out:  cubic-bezier(0.45, 0, 0.55, 1);
    }

    /* ─── RESET ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* ─── NAV ─────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 28px 40px;
      transition: padding 0.4s var(--ease-out), background 0.4s var(--ease-out), backdrop-filter 0.4s;
    }
    .nav.scrolled {
      padding: 18px 40px;
      background: rgba(249, 247, 244, 0.88);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(26, 25, 23, 0.06);
    }
    .nav__logo {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: var(--white);
      transition: color 0.4s;
    }
    .nav.scrolled .nav__logo { color: var(--text); }
    .nav__links {
      display: flex;
      gap: 36px;
      list-style: none;
    }
    .nav__links a {
      font-size: 0.8rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
      transition: color 0.3s;
      position: relative;
    }
    .nav__links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: currentColor;
      transition: width 0.3s var(--ease-out);
    }
    .nav__links a:hover::after { width: 100%; }
    .nav__links a:hover { color: rgba(255,255,255,1); }
    .nav.scrolled .nav__links a { color: var(--text-muted); }
    .nav.scrolled .nav__links a:hover { color: var(--text); }
    .nav__cta {
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 10px 22px;
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 2px;
      color: var(--white);
      transition: all 0.3s;
    }
    .nav__cta:hover {
      background: var(--white);
      color: var(--text);
      border-color: var(--white);
    }
    .nav.scrolled .nav__cta {
      border-color: var(--text);
      color: var(--text);
    }
    .nav.scrolled .nav__cta:hover {
      background: var(--text);
      color: var(--white);
    }

    /* mobile nav toggle */
    .nav__hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
      background: none;
      border: none;
    }
    .nav__hamburger span {
      display: block;
      width: 24px;
      height: 1.5px;
      background: var(--white);
      transition: background 0.4s, transform 0.3s, opacity 0.3s;
    }
    .nav.scrolled .nav__hamburger span { background: var(--text); }

    @media (max-width: 768px) {
      .nav { padding: 22px 24px; }
      .nav.scrolled { padding: 16px 24px; }
      .nav__links, .nav__cta { display: none; }
      .nav__hamburger { display: flex; }
    }

    /* ─── HERO – DESKTOP ──────────────────────────────────── */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 600px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
    }
    .hero__bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1800'); /* placeholder — restaurant interior */
      background-size: cover;
      background-position: center;
      transform: scale(1.06);
      animation: kenBurns 14s var(--ease-in-out) forwards;
      will-change: transform;
    }

    /* 
      REAL IMAGES: swap background-image URLs below.
      Desktop hero = IMG_9967.JPG (restaurant interior)
      Mobile hero  = IMG_3746.jpeg (overhead tomato dish)
    */
    .hero__bg--desktop {
      /* background-image: url('../IMG_9967.JPG'); */
    }

    @keyframes kenBurns {
      from { transform: scale(1.06); }
      to   { transform: scale(1.00); }
    }

    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(10, 9, 8, 0.75) 0%,
        rgba(10, 9, 8, 0.2)  50%,
        rgba(10, 9, 8, 0.1)  100%
      );
    }
    .hero__content {
      position: relative;
      z-index: 2;
      padding: 0 72px 80px;
      max-width: 900px;
    }
    .hero__eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-warm);
      margin-bottom: 20px;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease-out) 0.3s forwards;
    }
    .hero__headline {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 7vw, 6.5rem);
      font-weight: 300;
      line-height: 1.0;
      color: var(--white);
      letter-spacing: -0.01em;
      margin-bottom: 28px;
      opacity: 0;
      animation: fadeUp 0.9s var(--ease-out) 0.5s forwards;
    }
    .hero__headline em {
      font-style: italic;
      font-weight: 300;
      color: var(--accent-warm);
    }
    .hero__sub {
      font-size: 1rem;
      font-weight: 300;
      color: rgba(255,255,255,0.68);
      max-width: 420px;
      line-height: 1.65;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease-out) 0.7s forwards;
    }
    .hero__cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--white);
      padding: 14px 28px;
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 2px;
      opacity: 0;
      animation: fadeUp 0.8s var(--ease-out) 0.9s forwards;
      transition: all 0.3s;
    }
    .hero__cta:hover {
      background: var(--white);
      color: var(--text);
      border-color: var(--white);
      gap: 16px;
    }
    .hero__cta svg { width: 14px; height: 14px; transition: transform 0.3s; }
    .hero__cta:hover svg { transform: translateX(3px); }

    /* mobile hero override */
    @media (max-width: 768px) {
      .hero__content { padding: 0 28px 64px; }
      .hero__bg {
        /* background-image: url('../IMG_3746.jpeg'); */
        background-image: url('https://images.unsplash.com/photo-1476224203421-9ac39bcb3327?w=900');
        background-position: center top;
      }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── INTRO STRIP ─────────────────────────────────────── */
    .intro {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-bottom: 1px solid rgba(26, 25, 23, 0.1);
    }
    .intro__left {
      padding: 80px 72px;
      border-right: 1px solid rgba(26, 25, 23, 0.1);
    }
    .intro__right {
      padding: 80px 72px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .intro__label {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 24px;
    }
    .intro__headline {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 300;
      line-height: 1.15;
      color: var(--text);
      letter-spacing: -0.01em;
    }
    .intro__headline em {
      font-style: italic;
      color: var(--accent);
    }
    .intro__body {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.75;
      max-width: 340px;
    }
    .intro__stat {
      margin-top: 48px;
    }
    .intro__stat-number {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 300;
      color: var(--text);
      line-height: 1;
    }
    .intro__stat-label {
      font-size: 0.78rem;
      color: var(--text-muted);
      letter-spacing: 0.08em;
      margin-top: 6px;
    }

    @media (max-width: 768px) {
      .intro { grid-template-columns: 1fr; }
      .intro__left, .intro__right {
        padding: 56px 28px;
        border-right: none;
        border-bottom: 1px solid rgba(26, 25, 23, 0.1);
      }
    }

    /* ─── PORTFOLIO GRID ──────────────────────────────────── */
    .portfolio {
      padding: 100px 40px;
    }
    .portfolio__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 56px;
      padding: 0 32px;
    }
    .portfolio__title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 300;
      letter-spacing: -0.01em;
    }
    .portfolio__title em { font-style: italic; color: var(--accent); }
    .portfolio__meta {
      font-size: 0.78rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    /* Asymmetric editorial grid — the signature layout decision */
    .portfolio__grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      grid-template-rows: auto;
      gap: 3px;
    }
    .portfolio__item {
      overflow: hidden;
      position: relative;
      background: var(--surface);
    }
    .portfolio__item--tall {
      grid-row: span 2;
    }
    .portfolio__item--wide {
      grid-column: span 2;
    }
    .portfolio__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s var(--ease-out);
      display: block;
      /* Ensure consistent heights */
    }
    .portfolio__item:hover .portfolio__img {
      transform: scale(1.04);
    }
    .portfolio__caption {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 28px 28px 24px;
      background: linear-gradient(to top, rgba(10,9,8,0.7) 0%, transparent 100%);
      opacity: 0;
      transition: opacity 0.4s var(--ease-out);
    }
    .portfolio__item:hover .portfolio__caption { opacity: 1; }
    .portfolio__caption-text {
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.8);
    }

    /* Specific heights for grid cells */
    .portfolio__item--tall .portfolio__img { height: 680px; }
    .portfolio__item:not(.portfolio__item--tall):not(.portfolio__item--wide) .portfolio__img { height: 332px; }
    .portfolio__item--wide .portfolio__img { height: 480px; }

    @media (max-width: 768px) {
      .portfolio { padding: 64px 0; }
      .portfolio__header { padding: 0 24px; margin-bottom: 36px; }
      .portfolio__meta { display: none; }
      .portfolio__grid { grid-template-columns: 1fr; gap: 2px; }
      .portfolio__item--tall,
      .portfolio__item--wide { grid-row: span 1; grid-column: span 1; }
      .portfolio__item--tall .portfolio__img,
      .portfolio__item:not(.portfolio__item--tall):not(.portfolio__item--wide) .portfolio__img,
      .portfolio__item--wide .portfolio__img { height: 72vw; }
    }

    /* ─── PROCESS / DARK SECTION ──────────────────────────── */
    .process {
      background: var(--bg-dark);
      padding: 120px 72px;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
      align-items: start;
    }
    .process__left {}
    .process__eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 28px;
    }
    .process__headline {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 4vw, 3.6rem);
      font-weight: 300;
      line-height: 1.1;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .process__headline em { font-style: italic; color: var(--accent-warm); }
    .process__body {
      margin-top: 36px;
      font-size: 0.95rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.8;
      max-width: 380px;
    }
    .process__steps { list-style: none; margin-top: 16px; }
    .process__step {
      padding: 32px 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 20px;
      align-items: start;
    }
    .process__step:first-child { border-top: 1px solid rgba(255,255,255,0.07); }
    .process__step-num {
      font-family: var(--font-display);
      font-size: 0.85rem;
      color: var(--accent);
      padding-top: 3px;
    }
    .process__step-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 300;
      color: var(--white);
      margin-bottom: 8px;
      letter-spacing: 0.01em;
    }
    .process__step-body {
      font-size: 0.88rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.7;
    }

    @media (max-width: 768px) {
      .process {
        grid-template-columns: 1fr;
        padding: 80px 28px;
        gap: 56px;
      }
      .process__body { max-width: 100%; }
    }

    /* ─── QUOTE PULL ──────────────────────────────────────── */
    .quote {
      padding: 100px 72px;
      display: flex;
      align-items: center;
      gap: 60px;
      border-bottom: 1px solid rgba(26, 25, 23, 0.1);
    }
    .quote__line {
      width: 1px;
      height: 80px;
      background: var(--accent);
      flex-shrink: 0;
    }
    .quote__content {}
    .quote__text {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1.3;
      color: var(--text);
      max-width: 680px;
    }
    .quote__attribution {
      margin-top: 24px;
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    @media (max-width: 768px) {
      .quote { padding: 64px 28px; gap: 28px; flex-direction: column; }
      .quote__line { width: 40px; height: 1px; }
    }

    /* ─── CONTACT ─────────────────────────────────────────── */
    .contact {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .contact__left {
      background: var(--bg-dark);
      padding: 100px 72px;
    }
    .contact__right {
      background: var(--surface);
      padding: 100px 72px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .contact__eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 28px;
    }
    .contact__headline {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 4vw, 3.8rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .contact__headline em { font-style: italic; color: var(--accent-warm); }
    .contact__body {
      margin-top: 32px;
      font-size: 0.92rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.75;
      max-width: 340px;
    }
    .contact__detail {
      margin-top: 48px;
    }
    .contact__detail-label {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 8px;
    }
    .contact__detail-value {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 300;
      color: var(--white);
      letter-spacing: 0.02em;
    }
    .contact__detail-value a {
      color: inherit;
      border-bottom: 1px solid rgba(255,255,255,0.15);
      transition: border-color 0.3s;
    }
    .contact__detail-value a:hover { border-color: var(--accent-warm); }

    /* form */
    .form { display: flex; flex-direction: column; gap: 20px; }
    .form__field { display: flex; flex-direction: column; gap: 8px; }
    .form__label {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .form__input,
    .form__textarea {
      background: var(--bg);
      border: 1px solid rgba(26,25,23,0.12);
      border-radius: 2px;
      padding: 14px 16px;
      font-family: var(--font-body);
      font-size: 0.92rem;
      color: var(--text);
      transition: border-color 0.3s;
      outline: none;
      width: 100%;
    }
    .form__input:focus,
    .form__textarea:focus {
      border-color: var(--accent);
    }
    .form__textarea { resize: none; height: 120px; }
    .form__submit {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-body);
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--text);
      border: none;
      padding: 16px 32px;
      border-radius: 2px;
      cursor: pointer;
      align-self: flex-start;
      transition: background 0.3s, gap 0.3s;
    }
    .form__submit:hover {
      background: var(--accent);
      gap: 16px;
    }
    .form__submit:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    @media (max-width: 768px) {
      .contact { grid-template-columns: 1fr; }
      .contact__left, .contact__right { padding: 64px 28px; }
    }

    /* ─── FOOTER ──────────────────────────────────────────── */
    .footer {
      background: var(--bg-dark);
      padding: 36px 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .footer__logo {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 400;
      color: rgba(255,255,255,0.6);
    }
    .footer__copy {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.06em;
    }
    .footer__links {
      display: flex;
      gap: 28px;
      list-style: none;
    }
    .footer__links a {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      transition: color 0.3s;
    }
    .footer__links a:hover { color: rgba(255,255,255,0.7); }

    @media (max-width: 768px) {
      .footer {
        flex-direction: column;
        gap: 20px;
        padding: 36px 28px;
        text-align: center;
      }
      .footer__links { justify-content: center; }
    }

    /* ─── REVEAL ANIMATIONS ───────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.75s var(--ease-out), transform 0.75s var(--ease-out);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal[data-delay="1"] { transition-delay: 80ms; }
    .reveal[data-delay="2"] { transition-delay: 160ms; }
    .reveal[data-delay="3"] { transition-delay: 240ms; }
    .reveal[data-delay="4"] { transition-delay: 320ms; }
    .reveal[data-delay="5"] { transition-delay: 400ms; }
  </style>
</head>
<body>

  <!-- ─── NAV ───────────────────────────────────────────── -->
  <nav class="nav" id="nav">
    <a href="/" class="nav__logo">Sawyer & Co</a>
    <ul class="nav__links">
      <li><a href="#portfolio">Work</a></li>
      <li><a href="#process">Process</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <a href="#contact" class="nav__cta">Book a shoot</a>
    <button class="nav__hamburger" aria-label="Menu">
      <span></span><span></span>
    </button>
  </nav>

  <!-- ─── HERO ───────────────────────────────────────────── -->
  <!--
    Desktop hero image: IMG_9967.JPG (restaurant interior, candlelit, atmospheric)
    Mobile hero image:  IMG_3746.jpeg (overhead tomato dish, graphic composition)

    To wire up real images:
    1. Host images or use relative paths
    2. Uncomment the CSS rules in .hero__bg--desktop and the mobile override
    3. Remove the placeholder unsplash URLs
  -->
  <section class="hero">
    <div class="hero__bg hero__bg--desktop"></div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__eyebrow">Hospitality Photography</p>
      <h1 class="hero__headline">Photography for<br>restaurants <em>worth<br>remembering.</em></h1>
      <p class="hero__sub">We make the food look as good as it tastes — and the room feel as good as it is.</p>
      <a href="#portfolio" class="hero__cta">
        View the work
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M1 7h12M7 1l6 6-6 6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ─── INTRO ──────────────────────────────────────────── -->
  <section class="intro">
    <div class="intro__left">
      <p class="intro__label reveal">About</p>
      <h2 class="intro__headline reveal" data-delay="1">
        Imagery that fills<br><em>seats, not just feeds.</em>
      </h2>
    </div>
    <div class="intro__right">
      <p class="intro__body reveal" data-delay="2">
        Jay Sawyer is a UK-based hospitality photographer working with restaurants, bars, and hotels to create images that do one thing: make people want to be there. Every frame is considered against the brand, the light, and the guest's first impression.
      </p>
      <div class="intro__stat reveal" data-delay="3">
        <div class="intro__stat-number">7+</div>
        <div class="intro__stat-label">Years in hospitality photography</div>
      </div>
    </div>
  </section>

  <!-- ─── PORTFOLIO ──────────────────────────────────────── -->
  <!--
    Image selection rationale (strongest 5 from the shoot):
    1. IMG_3746.jpeg  — overhead tomato dish   [TALL, left col]
    2. IMG_0044.jpeg  — salmon carpaccio       [right col, top]
    3. IMG_3658.jpeg  — Christmas beef plate   [right col, bottom]
    4. IMG_3937.JPG   — espresso pull          [WIDE, full width]
    5. IMG_9967.JPG   — restaurant interior    [hero only]

    Dropped: IMG_3845.JPG (café shelves), IMG_8265.jpeg (full breakfast),
             IMG_8421.jpeg (sandwich) — tier below the rest
  -->
  <section class="portfolio" id="portfolio">
    <div class="portfolio__header">
      <h2 class="portfolio__title reveal">Selected <em>work</em></h2>
      <span class="portfolio__meta reveal" data-delay="1">Restaurants · Hotels · Bars</span>
    </div>

    <div class="portfolio__grid">

      <!-- TALL LEFT: overhead tomato dish — strong graphic composition -->
      <div class="portfolio__item portfolio__item--tall reveal">
        <img
          class="portfolio__img"
          src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=900"
          alt="Overhead fine dining dish — tomato with accompaniments"
          loading="lazy"
          width="900"
          height="680"
        />
        <!-- REPLACE: IMG_3746.jpeg -->
        <div class="portfolio__caption">
          <span class="portfolio__caption-text">Fine dining · Starters</span>
        </div>
      </div>

      <!-- RIGHT TOP: salmon carpaccio -->
      <div class="portfolio__item reveal" data-delay="1">
        <img
          class="portfolio__img"
          src="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800"
          alt="Salmon carpaccio with cream and herbs"
          loading="lazy"
          width="800"
          height="332"
        />
        <!-- REPLACE: IMG_0044.jpeg -->
        <div class="portfolio__caption">
          <span class="portfolio__caption-text">Seafood · Sharing plates</span>
        </div>
      </div>

      <!-- RIGHT BOTTOM: Christmas beef -->
      <div class="portfolio__item reveal" data-delay="2">
        <img
          class="portfolio__img"
          src="https://images.unsplash.com/photo-1544025162-d76694265947?w=800"
          alt="Rare beef slices with seasonal accompaniments"
          loading="lazy"
          width="800"
          height="332"
        />
        <!-- REPLACE: IMG_3658.jpeg -->
        <div class="portfolio__caption">
          <span class="portfolio__caption-text">Seasonal menus · Main courses</span>
        </div>
      </div>

      <!-- WIDE FULL: espresso pull — the craft shot -->
      <div class="portfolio__item portfolio__item--wide reveal">
        <img
          class="portfolio__img"
          src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1600"
          alt="Espresso being pulled on a La Marzocco machine"
          loading="lazy"
          width="1600"
          height="480"
        />
        <!-- REPLACE: IMG_3937.JPG -->
        <div class="portfolio__caption">
          <span class="portfolio__caption-text">Coffee · Craft &amp; process</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── PULL QUOTE ─────────────────────────────────────── -->
  <blockquote class="quote">
    <div class="quote__line"></div>
    <div class="quote__content">
      <p class="quote__text reveal">
        "Good hospitality photography isn't about making food look perfect. It's about making the whole room feel like somewhere you'd rather be."
      </p>
      <p class="quote__attribution reveal" data-delay="1">— Jay Sawyer, Sawyer &amp; Co</p>
    </div>
  </blockquote>

  <!-- ─── PROCESS ────────────────────────────────────────── -->
  <section class="process" id="process">
    <div class="process__left">
      <p class="process__eyebrow reveal">How it works</p>
      <h2 class="process__headline reveal" data-delay="1">
        A shoot built<br>around <em>your service,</em><br>not ours.
      </h2>
      <p class="process__body reveal" data-delay="2">
        Every hospitality venue is different. The brief, the timing, the mood. We don't show up with a preset. We come in during service, understand the rhythm, and find the frames that belong to your place.
      </p>
    </div>
    <div class="process__right">
      <ul class="process__steps">
        <li class="process__step reveal">
          <span class="process__step-num">01</span>
          <div>
            <p class="process__step-title">The brief call</p>
            <p class="process__step-body">30 minutes. We cover your audience, your positioning, and what the images need to do — not just how they should look.</p>
          </div>
        </li>
        <li class="process__step reveal" data-delay="1">
          <span class="process__step-num">02</span>
          <div>
            <p class="process__step-title">Shoot day</p>
            <p class="process__step-body">Half or full-day on-site. We work around your service, not instead of it. Ambient light where possible, no artificial staging.</p>
          </div>
        </li>
        <li class="process__step reveal" data-delay="2">
          <span class="process__step-num">03</span>
          <div>
            <p class="process__step-title">Edited delivery</p>
            <p class="process__step-body">A curated gallery of 40–80 retouched images, sized for web, print, and social. Delivered within 7 days.</p>
          </div>
        </li>
        <li class="process__step reveal" data-delay="3">
          <span class="process__step-num">04</span>
          <div>
            <p class="process__step-title">Usage rights</p>
            <p class="process__step-body">Full commercial licence included. No ongoing fees, no credit requirements. The images are yours.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ─── CONTACT ────────────────────────────────────────── -->
  <section class="contact" id="contact">
    <div class="contact__left">
      <p class="contact__eyebrow reveal">Get in touch</p>
      <h2 class="contact__headline reveal" data-delay="1">
        Let's make<br>something<br><em>worth eating.</em>
      </h2>
      <p class="contact__body reveal" data-delay="2">
        Whether you're launching, rebranding, or just need images that convert — get in touch and we'll talk through what makes sense.
      </p>
      <div class="contact__detail reveal" data-delay="3">
        <p class="contact__detail-label">Email</p>
        <!-- REPLACE: actual email -->
        <p class="contact__detail-value"><a href="mailto:hello@sawyerandcophotography.co.uk">hello@sawyerandco<wbr>photography.co.uk</a></p>
      </div>
      <div class="contact__detail reveal" data-delay="4">
        <p class="contact__detail-label">Based in</p>
        <p class="contact__detail-value">United Kingdom</p>
      </div>
    </div>
    <div class="contact__right">
      <form class="form" onsubmit="handleSubmit(event)">
        <div class="form__field">
          <label class="form__label" for="name">Your name</label>
          <input class="form__input" type="text" id="name" name="name" placeholder="Alex Thornton" required />
        </div>
        <div class="form__field">
          <label class="form__label" for="email">Email address</label>
          <input class="form__input" type="email" id="email" name="email" placeholder="alex@restaurant.co.uk" required />
        </div>
        <div class="form__field">
          <label class="form__label" for="message">Tell me about the project</label>
          <textarea class="form__textarea" id="message" name="message" placeholder="We're a 40-cover bistro in East London looking to refresh our website imagery…" required></textarea>
        </div>
        <button class="form__submit" type="submit">
          Send enquiry
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1 7h12M7 1l6 6-6 6"/>
          </svg>
        </button>
      </form>
    </div>
  </section>

  <!-- ─── FOOTER ─────────────────────────────────────────── -->
  <footer class="footer">
    <span class="footer__logo">Sawyer &amp; Co</span>
    <ul class="footer__links">
      <li><a href="#portfolio">Work</a></li>
      <li><a href="#process">Process</a></li>
      <li><a href="mailto:hello@sawyerandcophotography.co.uk">Contact</a></li>
    </ul>
    <p class="footer__copy">© 2026 Sawyer &amp; Co. All rights reserved.</p>
  </footer>

  <!-- ─── JS ─────────────────────────────────────────────── -->
  <script>
    // Nav scroll state
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    // Reveal on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(el => {
        if (el.isIntersecting) {
          el.target.classList.add('visible');
          observer.unobserve(el.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Form submit (placeholder — wire to Formspree or similar)
    function handleSubmit(e) {
      e.preventDefault();
      const btn = e.target.querySelector('.form__submit');
      btn.textContent = 'Sent — we\'ll be in touch.';
      btn.style.background = '#4a7c59';
      btn.disabled = true;
    }
  </script>
</body>
</html>
